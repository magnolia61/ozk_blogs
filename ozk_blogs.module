<?php

/**
 * @file
 * OZK Blogs: alle Drupal-logica rond het content type Article (blog) op één
 * plek, in plaats van verspreid over losse Rules en theme-form-alters.
 *
 * Vervangt drie Drupal Rules die zijn uitgeschakeld (niet verwijderd) na de
 * migratie naar deze module:
 * - "Corrigeer Datum blog"   (rules_corrigeer_datum_blog)
 * - "BLOG aanpassen titel"   (rules_blog_aanpassen_titel)
 * - "Nieuwe Blog online"     (rules_nieuwe_blog_online)
 *
 * En vervangt de tijdelijke form_alter die eerder in het Porto_sub-theme
 * stond (porto_sub_form_article_node_form_alter).
 */

/**
 * Implements hook_admin_paths_alter().
 *
 * Haalt het blog aanmaak-/bewerkformulier uit de "admin"-paden, zodat het in
 * het standaard front-end-thema (Porto_sub) rendert i.p.v. Seven. Dit is de
 * juiste plek: node_admin_theme forceert Seven via de admin-pad-detectie en
 * die theme-callback wint van hook_custom_theme(). Door het pad hier als
 * niet-admin (FALSE) te markeren valt het terug op het standaardthema.
 *
 * De globale instelling node_admin_theme blijft ongemoeid, dus overig beheer
 * blijft in Seven.
 */
function ozk_blogs_admin_paths_alter(&$paths) {
  // Blog aanmaken -> front-end-thema.
  $paths['node/add/article'] = FALSE;

  // Blog bewerken -> alleen voor article-nodes front-end-thema. Er is geen
  // type-specifiek padpatroon voor node/%/edit, dus markeer alleen het
  // huidige pad als het om een article gaat.
  if (arg(0) === 'node' && is_numeric(arg(1)) && arg(2) === 'edit') {
    $node = node_load(arg(1));
    if ($node && $node->type === 'article') {
      $paths[current_path()] = FALSE;
    }
  }
}

/**
 * Implements hook_node_presave().
 */
function ozk_blogs_node_presave($node) {
  if ($node->type !== 'article') {
    return;
  }

  ozk_blogs_datum_corrigeren($node);
  ozk_blogs_titel_samenstellen($node);
  ozk_blogs_tag_afleiden($node);
}

/**
 * Vult Datum met de aanmaakdatum van de node als het veld leeg is.
 * Vervangt Rule "Corrigeer Datum blog".
 */
function ozk_blogs_datum_corrigeren(&$node) {
  $langcode    = LANGUAGE_NONE;
  $heeft_datum = !empty($node->field_datum[$langcode][0]['value']);

  if (!$heeft_datum) {
    // field_datum is van het Date-module veldtype 'date' (ISO-opslag zonder
    // tijdzone) — zelfde opslagformaat als de rest van de site gebruikt.
    $node->field_datum[$langcode][0]['value'] = gmdate('Y-m-d\TH:i:s', $node->created);
  }
}

/**
 * Stelt de node-titel samen uit Datum + Kamp categorie + Blognaam.
 * Vervangt Rule "BLOG aanpassen titel".
 *
 * Format: "d/m kampcode: blognaam", bv. "23/07 jk1: woensdag" — exact het
 * format dat de oude Rule ook produceerde, zodat bestaande URL's/gewoontes
 * niet veranderen.
 */
function ozk_blogs_titel_samenstellen(&$node) {
  $langcode  = LANGUAGE_NONE;
  $blogtitel = trim($node->field_blogtitel[$langcode][0]['value'] ?? '');

  // Zelfde voorwaarde als de oude Rule: alleen aanpassen als Blognaam is ingevuld.
  if ($blogtitel === '') {
    return;
  }

  $datum_value = $node->field_datum[$langcode][0]['value'] ?? NULL;
  $datum_fmt   = $datum_value ? gmdate('d/m', strtotime($datum_value)) : '';

  $kamp_code = '';
  $kamp_tid  = $node->field_kamp_categorie[$langcode][0]['tid'] ?? NULL;
  if ($kamp_tid) {
    $term = taxonomy_term_load($kamp_tid);
    if ($term) {
      // 'description' bevat de korte kampcode (bv. "jk1"), niet de volledige naam.
      $kamp_code = trim($term->description);
    }
  }

  $node->title = trim("{$datum_fmt} {$kamp_code}: {$blogtitel}");
}

/**
 * Zet automatisch de kamptype-tag op basis van het gekozen kamp.
 *
 * Het bovenste niveau van field_kamp_categorie (kinderkamp / brugkamp /
 * tienerkamp / jeugdkamp / topkamp) heeft in de 'tags'-vocabulaire een
 * gelijknamige term. Die tag wordt hier toegevoegd zodat de hoofdleiding
 * 'm niet meer handmatig hoeft aan te vinken.
 *
 * Bestaande, handmatig gekozen tags (bv. jubileum, ouders) blijven staan:
 * de kamptype-tag wordt toegevoegd, niet overschreven. Zo blijft het
 * tags-veld op het formulier bruikbaar voor eventuele extra tags.
 *
 * Voor kamp 'algemeen' (of geen kamp) is er geen kamptype-tag; dan gebeurt
 * er niets en kan men eventueel zelf een tag aanvinken.
 */
function ozk_blogs_tag_afleiden(&$node) {
  $langcode = LANGUAGE_NONE;

  $kamp_tid = $node->field_kamp_categorie[$langcode][0]['tid'] ?? NULL;
  if (!$kamp_tid) {
    return;
  }

  // Bovenste niveau (root) van de gekozen kampterm bepalen.
  $parents = taxonomy_get_parents_all($kamp_tid);
  $root    = end($parents);
  if (!$root) {
    return;
  }

  // Gelijknamige term zoeken in de 'tags'-vocabulaire.
  $tag_terms = taxonomy_get_term_by_name($root->name, 'tags');
  if (empty($tag_terms)) {
    return;
  }
  $tag_term = reset($tag_terms);

  // Bestaande tags verzamelen en de kamptype-tag toevoegen als die er nog
  // niet bij staat (niet overschrijven).
  $huidige_tids = [];
  if (!empty($node->field_tags[$langcode])) {
    foreach ($node->field_tags[$langcode] as $item) {
      if (!empty($item['tid'])) {
        $huidige_tids[] = $item['tid'];
      }
    }
  }

  if (!in_array($tag_term->tid, $huidige_tids)) {
    $node->field_tags[$langcode][] = ['tid' => $tag_term->tid];
  }
}

/**
 * Implements hook_node_insert().
 */
function ozk_blogs_node_insert($node) {
  if ($node->type !== 'article' || empty($node->status)) {
    return;
  }

  ozk_blogs_activiteit_loggen($node);
}

/**
 * Logt een CiviCRM-activiteit (activity_type_id 149) zodra een nieuwe blog
 * live gaat. Vervangt Rule "Nieuwe Blog online".
 */
function ozk_blogs_activiteit_loggen($node) {
  $extdebug = 'ozk_blogs';
  $apidebug = FALSE;

  if (!civicrm_initialize()) {
    watchdog($extdebug, 'activiteit_loggen: civicrm_initialize mislukt — stop.', [], WATCHDOG_ERROR);
    return;
  }

  $langcode = LANGUAGE_NONE;

  $auteur_cid = CRM_Core_BAO_UFMatch::getContactId($node->uid);
  if (!$auteur_cid) {
    wachthond($extdebug, 1, 'activiteit_loggen: geen CiviCRM-contact voor auteur uid', $node->uid);
    return;
  }

  $kamp_tid  = $node->field_kamp_categorie[$langcode][0]['tid'] ?? NULL;
  $kamp_naam = '';
  if ($kamp_tid) {
    $term      = taxonomy_term_load($kamp_tid);
    $kamp_naam = $term ? $term->name : '';
  }

  // De oude Rule gebruikte "site:current-user" (niet de node-auteur) voor de
  // omschrijving in 'details' — dat kan afwijken van de auteur als iemand
  // anders' blog wordt bewerkt/gepubliceerd. Zelfde gedrag overgenomen.
  global $user;
  $details     = '';
  $huidige_cid = CRM_Core_BAO_UFMatch::getContactId($user->uid);
  if ($huidige_cid) {
    $params_contact_huidige = [
        'checkPermissions' => FALSE,
        'debug'            => $apidebug,
        'select'           => ['display_name'],
        'where'            => [['id', '=', $huidige_cid]],
    ];
    wachthond($extdebug, 7, 'params_contact_huidige', $params_contact_huidige);
    $result_contact_huidige = civicrm_api4('Contact', 'get', $params_contact_huidige);
    wachthond($extdebug, 9, 'result_contact_huidige', $result_contact_huidige);

    $details = $result_contact_huidige[0]['display_name'] ?? '';
  }

  $params_activity_nieuweblog = [
      'checkPermissions' => FALSE,
      'debug'            => $apidebug,
      'values'           => [
          'activity_type_id'  => 149,
          'source_contact_id' => $auteur_cid,
          'source_record_id'  => $auteur_cid,
          'subject'           => "nieuwe blog over {$kamp_naam}",
          'location'          => $kamp_naam,
          'details'           => $details,
          'status_id'         => 2,
      ],
  ];
  wachthond($extdebug, 7, 'params_activity_nieuweblog', $params_activity_nieuweblog);
  $result_activity_nieuweblog = civicrm_api4('Activity', 'create', $params_activity_nieuweblog);
  wachthond($extdebug, 9, 'result_activity_nieuweblog', $result_activity_nieuweblog);
}

/**
 * Implements hook_form_alter().
 *
 * Verbergt het (verplichte, niet te verwijderen) core titelveld op het blog
 * aanmaak-/bewerkformulier. De module exclude_node_title doet dit al bij
 * bewerken (node/%/edit) maar bewust niet bij aanmaken (node/add/article,
 * zie exclude_node_title_preprocess_page()). De titel wordt sowieso
 * automatisch samengesteld door ozk_blogs_titel_samenstellen() hierboven.
 *
 * Verbergt ook het tags-veld: de kamptype-tag wordt automatisch afgeleid uit
 * het kamp (zie ozk_blogs_tag_afleiden()), dus de hoofdleiding hoeft hier
 * niets meer te kiezen. #access = FALSE laat bestaande, reeds opgeslagen tags
 * intact bij bewerken.
 */
function ozk_blogs_form_article_node_form_alter(&$form, &$form_state, $form_id) {
  $form['title']['#access']   = FALSE;
  $form['title']['#required'] = FALSE;

  if (isset($form['field_tags'])) {
    $form['field_tags']['#access'] = FALSE;
  }

  // Compacter formulier: minder verticale witruimte tussen de velden zodat het
  // Body-veld niet zo ver naar beneden staat. CSS is gescoped op de klasse
  // hieronder, dus andere formulieren op de site blijven ongemoeid.
  $form['#attributes']['class'][] = 'ozk-blog-form';
  $form['#attached']['css'][] = drupal_get_path('module', 'ozk_blogs') . '/ozk_blogs.form.css';
}
